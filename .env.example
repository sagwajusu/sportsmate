# Frontend
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://127.0.0.1:5002
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-or-publishable-key>
# Public frontend origin for QR links. Leave empty to use the current browser origin.
# For local mobile testing, set this to the frontend origin using the PC LAN IP.
VITE_QR_PUBLIC_ORIGIN=

# Backend
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5002
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>.supabase.com:5432/postgres?sslmode=require
JWT_SECRET_KEY=change-this-secret-at-least-32-bytes-long
SQLALCHEMY_NULL_POOL=true
SQLALCHEMY_POOL_SIZE=1
SQLALCHEMY_MAX_OVERFLOW=0
SQLALCHEMY_POOL_TIMEOUT=10
SQLALCHEMY_POOL_RECYCLE=120
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-or-secret-key>

# Legacy static server (app.py)
STATIC_RUN_HOST=127.0.0.1
STATIC_RUN_PORT=8000

# External APIs
NAVER_MAP_CLIENT_ID=

VWORLD_API_KEY=
VWORLD_DOMAIN=
MOLIT_API_KEY=
MOLIT_REGION_API_URL=
NAVER_MAP_CLIENT_SECRET=
NAVER_DYNAMIC_MAP_CLIENT_ID=
NAVER_GEOCODE_URL=
NAVER_REVERSE_GEOCODE_URL=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_KEYWORD_SEARCH_URL=
KAKAO_ADDRESS_SEARCH_URL=
KAKAO_COORD2ADDRESS_URL=

# OpenAI chatbot
OPENAI_API_KEY=
OPENAI_CHATBOT_MODEL=gpt-5.2
